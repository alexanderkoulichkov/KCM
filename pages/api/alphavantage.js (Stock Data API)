export default async function handler(req, res) {
  if (req.method !== 'GET') {
    return res.status(405).json({ error: 'Method not allowed' });
  }

  const { symbol, function: fn } = req.query;
  const apiKey = process.env.ALPHA_VANTAGE_API_KEY;

  if (!apiKey) {
    return res.status(500).json({ error: 'Missing ALPHA_VANTAGE_API_KEY' });
  }

  if (!symbol) {
    return res.status(400).json({ error: 'Missing symbol parameter' });
  }

  try {
    const url = `https://www.alphavantage.co/query?function=${fn || 'TIME_SERIES_DAILY'}&symbol=${symbol}&outputsize=full&apikey=${apiKey}`;
    const response = await fetch(url);
    const data = await response.json();

    if (data.Note || data.Error) {
      return res.status(429).json({ error: data.Note || data.Error });
    }

    // Extract latest price data
    const timeSeries = data['Time Series (Daily)'];
    if (!timeSeries) {
      return res.status(200).json(data);
    }

    const dates = Object.keys(timeSeries).sort().reverse();
    const latest = timeSeries[dates[0]];

    res.status(200).json({
      symbol,
      date: dates[0],
      price: parseFloat(latest.close),
      high: parseFloat(latest.high),
      low: parseFloat(latest.low),
      volume: parseInt(latest.volume),
      raw: data,
    });
  } catch (error) {
    console.error('Alpha Vantage error:', error);
    res.status(500).json({ error: 'Failed to fetch stock data' });
  }
}
